{
  "name": "privacy-panel",
  "version": "0.1.0",
  "description": "Open-source privacy policy analyzer that renders FDA Nutrition Facts-style labels and A–F grades using a published rubric.",
  "license": "MIT",
  "homepage": "https://privacypanel.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/nd4spd13/privacy-panel.git"
  },
  "bugs": {
    "url": "https://github.com/nd4spd13/privacy-panel/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-public-artifacts.mjs",
    "build": "next build",
    "check:artifacts": "node scripts/check-public-artifacts.mjs",
    "audit:quotes": "npx tsx scripts/audit-quotes.ts",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scoring": "vitest run tests/core/scoring",
    "test:schema": "vitest run tests/core/schema",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.1",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "zod": "^3.25.76"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10"
  },
  "pnpm": {
    "overrides": {
      "picomatch": "^4.0.4",
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
