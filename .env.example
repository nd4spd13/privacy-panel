# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real credentials.

# Optional: path to the SQLite database (default: ./data/privacypanel.db)
DATABASE_URL=./data/privacypanel.db

# Optional: canonical base URL for the site (used in og:url, sitemaps, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Emergency kill switch — set to "false" to hide all scores, grades, and
# the /rubric page without redeploying. See docs/SHOW_SCORES.md.
# SHOW_SCORES=false
