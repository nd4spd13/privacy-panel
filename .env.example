# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real credentials.

# Required: Anthropic API key for privacy policy extraction
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: path to the SQLite database (default: ./data/privacyfacts.db)
DATABASE_URL=./data/privacyfacts.db

# Optional: canonical base URL for the site (used in og:url, sitemaps, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
