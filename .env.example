# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real credentials.

# Optional: path to the SQLite database (default: ./data/privacypanel.db)
DATABASE_URL=./data/privacypanel.db

# Optional: canonical base URL for the site (used in og:url, sitemaps, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Scoring layer gate — must be exactly "true" to show scores, grades, and /rubric.
# Absent or any other value keeps scores hidden (fail-closed default).
# See docs/SHOW_SCORES.md for the operator runbook.
# SHOW_SCORES=true
